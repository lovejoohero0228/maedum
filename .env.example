# .env.local로 복사해 사용 (AGENT.md §10)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_APP_ENV=development

# OPENAI_API_KEY는 클라이언트에 절대 노출 금지 —
# Supabase Edge Function 시크릿으로만 설정 (CLAUDE.md 참고: 원래 Anthropic이었으나
# 크레딧 문제로 OpenAI로 전환):
#   npx supabase secrets set OPENAI_API_KEY=sk-...
